<%= turbo_frame_tag dom_id(brewery, :stamp), class: "flex-1 sm:flex-none" do %>
  <% if stamp %>
    <%= button_to brewery_stamp_path(brewery), method: :delete, form_class: "w-full", class: "w-full flex items-center justify-center gap-2 rounded-xl bg-brew-700 dark:bg-brew-600 text-white font-semibold px-6 py-3 cursor-pointer" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
        <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
      </svg>
      Stamped
    <% end %>
  <% else %>
    <%= button_to brewery_stamp_path(brewery), form_class: "w-full", class: "w-full sm:max-w-xs flex items-center justify-center gap-2 rounded-xl bg-brew-800 dark:bg-brew-200 text-white dark:text-brew-900 font-semibold px-6 py-3 cursor-pointer hover:bg-brew-700 dark:hover:bg-brew-300 transition" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
      </svg>
      Stamp passport
    <% end %>
  <% end %>
<% end %>
