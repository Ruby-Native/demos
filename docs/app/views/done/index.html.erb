<% content_for :title, "Done" %>

<%= native_navbar_tag("Done") %>
<%= native_badge_tag(tab: Current.user.todos.pending.count) %>

<h1 class="<%= "native-hidden" if native_app? %>">Done</h1>

<% if @todos.any? %>
  <ul class="todos">
    <%= render partial: "todos/row", collection: @todos, as: :todo %>
  </ul>
<% else %>
  <div class="empty">
    <div class="empty-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <path d="M9 12l2 2 4-4"/>
      </svg>
    </div>
    <p>Nothing completed yet.</p>
  </div>
<% end %>
